<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
           xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0"
           xsi:type="MailApp">

  <Id>C41FD75D-E813-407E-BDF4-2E6405446166</Id>
  <Version>1.0.0.1</Version>
  <ProviderName>MailGuard</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="MailGuard"/>
  <Description DefaultValue="AI-powered spam and phishing detector for Outlook"/>
  <IconUrl DefaultValue="https://mailguard-inky.vercel.app/assets/icon-64.png"/>
  <HighResolutionIconUrl DefaultValue="https://mailguard-inky.vercel.app/assets/icon-128.png"/>
  <SupportUrl DefaultValue="https://github.com/jonrjackson/mailguard"/>

  <AppDomains>
    <AppDomain>https://mailguard-inky.vercel.app</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.1"/>
    </Sets>
  </Requirements>

  <!-- Required for validation / older clients, but ignored wherever VersionOverrides below is supported. -->
  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://mailguard-inky.vercel.app/taskpane.html"/>
        <RequestedHeight>450</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadItem</Permissions>

  <!-- Required for validation / older clients, but ignored wherever VersionOverrides below is supported. -->
  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read"/>
  </Rule>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides/1.1" xsi:type="VersionOverridesV1_1">
      <Requirements>
        <bt:Sets DefaultMinVersion="1.3">
          <bt:Set Name="Mailbox"/>
        </bt:Sets>
      </Requirements>
      <Hosts>
        <Host xsi:type="MailHost">
          <DesktopFormFactor>
            <!-- Activates the add-in's button on the Message Read ribbon. -->
            <ExtensionPoint xsi:type="MessageReadCommandSurface">
              <OfficeTab id="TabDefault">
                <Group id="msgReadGroup">
                  <Label resid="groupLabel"/>
                  <Control xsi:type="Button" id="msgReadOpenPaneButton">
                    <Label resid="taskPaneButtonLabel"/>
                    <Supertip>
                      <Title resid="taskPaneButtonLabel"/>
                      <Description resid="taskPaneButtonDescription"/>
                    </Supertip>
                    <Icon>
                      <bt:Image size="16" resid="icon16"/>
                      <bt:Image size="32" resid="icon32"/>
                      <bt:Image size="80" resid="icon80"/>
                    </Icon>
                    <Action xsi:type="ShowTaskpane">
                      <SourceLocation resid="messageReadTaskPaneUrl"/>
                    </Action>
                  </Control>
                </Group>
              </OfficeTab>
            </ExtensionPoint>
          </DesktopFormFactor>
        </Host>
      </Hosts>
      <Resources>
        <bt:Images>
          <bt:Image id="icon16" DefaultValue="https://mailguard-inky.vercel.app/assets/icon-64.png"/>
          <bt:Image id="icon32" DefaultValue="https://mailguard-inky.vercel.app/assets/icon-64.png"/>
          <bt:Image id="icon80" DefaultValue="https://mailguard-inky.vercel.app/assets/icon-128.png"/>
        </bt:Images>
        <bt:Urls>
          <bt:Url id="messageReadTaskPaneUrl" DefaultValue="https://mailguard-inky.vercel.app/taskpane.html"/>
        </bt:Urls>
        <bt:ShortStrings>
          <bt:String id="groupLabel" DefaultValue="MailGuard"/>
          <bt:String id="taskPaneButtonLabel" DefaultValue="MailGuard"/>
        </bt:ShortStrings>
        <bt:LongStrings>
          <bt:String id="taskPaneButtonDescription" DefaultValue="Check this email for spam and phishing."/>
        </bt:LongStrings>
      </Resources>
    </VersionOverrides>
  </VersionOverrides>

</OfficeApp>
